%%{init: {"theme": "base", "themeVariables": {"fontFamily": "SimSun, Microsoft YaHei, Arial", "fontSize": "18px", "primaryColor": "#ffffff", "primaryBorderColor": "#222222", "lineColor": "#222222", "tertiaryColor": "#ffffff"}, "flowchart": {"curve": "linear", "nodeSpacing": 180, "rankSpacing": 38, "htmlLabels": true}} }%%
flowchart TB
    A["前端选择扫描类型"] --> B{"任务类型"}

    B -->|SAST| C1["上传代码文件<br/>并选择扫描引擎"]
    B -->|DAST| C2["填写目标 URL<br/>并确认授权"]
    B -->|SCA| C3["上传 requirements 文件<br/>或 ZIP"]

    C1 --> D1["SAST 参数校验"]
    C2 --> D2["DAST URL 与授权校验"]
    C3 --> D3["SCA 文件类型<br/>与大小校验"]

    D1 --> E{"校验结果"}
    D2 --> E
    D3 --> E

    E -->|失败| F["返回错误<br/>并记录必要审计"]
    E -->|通过| G["创建 Task 主记录"]

    classDef node fill:#ffffff,stroke:#222222,stroke-width:1.4px,color:#111111;
    classDef decision fill:#ffffff,stroke:#222222,stroke-width:1.4px,color:#111111;
    class A,C1,C2,C3,D1,D2,D3,F,G node;
    class B,E decision;
